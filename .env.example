# ============================================
# OAuth Client ID 配置
# ============================================
#
# 说明：
# - 开发环境：无需配置，使用 js/oauth-config.js 中的映射表
# - 测试环境：配置相应的环境变量
# - 生产环境：通过 GitHub Secrets 自动注入
#
# 重要：
# - 每个市场的所有包 ID（开发/生产）使用相同的环境变量
# - 切勿将真实的生产环境 Client ID 提交到代码仓库
# - 所有生产环境配置通过 CI/CD Secrets 管理

# === Chrome Web Store（开发和生产共用）===
# 开发环境（无需配置，使用硬编码映射表）
# CHROME_GOOGLE_CLIENT_ID=
# CHROME_MICROSOFT_CLIENT_ID=

# 生产环境（由 GitHub Secrets 注入）
# CHROME_GOOGLE_CLIENT_ID=your-chrome-google-client-id
# CHROME_MICROSOFT_CLIENT_ID=your-chrome-microsoft-client-id

# === Edge Add-ons ===
# 生产环境（由 GitHub Secrets 注入）
# EDGE_GOOGLE_CLIENT_ID=your-edge-google-client-id
# EDGE_MICROSOFT_CLIENT_ID=your-edge-microsoft-client-id

# === Firefox Add-ons ===
# 生产环境（由 GitHub Secrets 注入）
# FIREFOX_GOOGLE_CLIENT_ID=your-firefox-google-client-id
# FIREFOX_MICROSOFT_CLIENT_ID=your-firefox-microsoft-client-id
